								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"publicKey\": \"{{public_key}}\"\n}"
						},
						"url": "{{base_url}}/get-address-from-public-key",
						"description": "Computes EVM address from an uncompressed public key."
					},
					"response": []
				}
