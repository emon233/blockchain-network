		{
			"name": "Wallet",
			"item": [
				{
					"name": "Generate wallet",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const json = pm.response.json();",
									"if (json && json.address) {",
									"    pm.collectionVariables.set('address', json.address);",
									"}",
									"if (json && json.privateKey) {",
									"    pm.collectionVariables.set('private_key', json.privateKey);",
									"}",
									"if (json && json.publicKey) {",
									"    pm.collectionVariables.set('public_key', json.publicKey);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": "{{base_url}}/generate-wallet",
						"description": "Creates a random wallet. Returns `address`, `privateKey`, `mnemonic`, `publicKey`."
					},
					"response": []
				},
				{
					"name": "Get wallet from private key",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"privateKey\": \"{{private_key}}\"\n}"
						},
						"url": "{{base_url}}/get-wallet-from-private-key",
						"description": "Derives wallet fields from a private key (with or without `0x` prefix)."
					},
					"response": []
				},
				{
					"name": "Get address from public key",
					"request": {
						"method": "POST",
						"header": [
